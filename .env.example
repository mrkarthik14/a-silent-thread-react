# Convex Configuration
# Get this URL from your Convex dashboard after running 'npx convex dev' or deploying
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex Site URL (for authentication)
CONVEX_SITE_URL=https://your-deployment.convex.site

# Convex Deployment (automatically set by 'npx convex dev')
CONVEX_DEPLOYMENT=dev:your-deployment

# VLY Integration (optional - for error monitoring and integrations)
VITE_VLY_APP_ID=your-vly-app-id
VITE_VLY_MONITORING_URL=https://runtime-monitoring.vly.ai/runtime-error

# Note: Do not commit .env.local or .env files to version control
# Add sensitive keys through Vercel dashboard for production deployment
